# OpenDental MySQL connection string (required)
# For Docker Desktop on Mac/Windows: host.docker.internal resolves to the host.
# For Linux: use the host IP address or --network=host.
ConnectionStrings__OpenDental=Server=host.docker.internal;Port=3306;Database=opendental;User=reader;Password=your_secure_password;Default Command Timeout=120;Pooling=True;MinimumPoolSize=2;MaximumPoolSize=10

# Frontend origin for CORS (optional, default http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# For demo mode, use:
# ConnectionStrings__OpenDental=Server=demo-db;Port=3306;Database=opendental;User=reader;Password=demoreader
