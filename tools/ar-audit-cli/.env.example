# OpenDental AR Audit CLI — Environment Configuration
#
# Copy this file to .env or export directly:
#   export OPENDENTAL_CONNECTION_STRING="..."
#
# The connection string uses ODBC-style MySQL syntax.

OPENDENTAL_CONNECTION_STRING="Server=localhost;Port=3306;Database=opendental;User=readonly;Password=your_password_here"

# ── Optional overrides ───────────────────────────────────────────
# AR_AUDIT_OUTPUT_DIR=audit-output
# AR_AUDIT_THRESHOLD=30
